# Monday.com BI Agent - Environment Configuration
# Copy this file to .env and fill in your values

# Flask Environment (development, production, testing)
FLASK_ENV=development

# Secret Key (CHANGE THIS IN PRODUCTION!)
SECRET_KEY=your-secret-key-here-generate-random-string

# Data File Paths
DEALS_FILE=C:/Users/Ashmith/Downloads/Deal funnel Data.xlsx
WORK_ORDERS_FILE=C:/Users/Ashmith/Downloads/Work_Order_Tracker Data.xlsx

# Data Refresh Settings
AUTO_REFRESH_INTERVAL=300
ENABLE_FILE_WATCHER=true

# Cache Settings
ENABLE_CACHE=true
CACHE_TTL=60

# Rate Limiting
RATELIMIT_ENABLED=true

# CORS Settings (comma-separated origins)
CORS_ORIGINS=*

# Monday.com API Settings (for live data integration)
MONDAY_API_KEY=your-monday-api-key-here
MONDAY_BOARD_ID_DEALS=your-deals-board-id
MONDAY_BOARD_ID_WORK_ORDERS=your-work-orders-board-id
USE_LIVE_API=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
